{
  "name": "@cli-tools/oh-my-sdd",
  "version": "0.1.0",
  "description": "企业级 SDD 工作流 + iam 身份校验 + DOP 埋点（Claude Code 插件）",
  "type": "module",
  "main": "install.js",
  "bin": {
    "hello-sdd": "bin/hello-sdd.js",
    "oms-install": "./bin/oms-install.js",
    "oms-uninstall": "./bin/oms-uninstall.js",
    "oms-login": "./bin/oms-login.js",
    "oms-wrapper-verify": "./bin/oms-wrapper-verify.js",
    "oms-update": "./bin/oms-update.js",
    "oms-git-hooks": "./bin/oms-git-hooks.js"
  },
  "scripts": {
    "postinstall": "node install.js",
    "preuninstall": "node uninstall.js",
    "test": "node scripts/run-tests.js",
    "test:glob": "node --test \"__tests__/**/*.test.js\"",
    "lint:baseline": "node scripts/check-baseline-tokens.mjs",
    "build:opencode": "cd opencode && npm install --no-audit --no-fund && npm run build"
  },
  "files": [
    ".claude-plugin/",
    "install.js",
    "uninstall.js",
    "bin/",
    "wrappers/",
    "skills/",
    "content/",
    "hooks/",
    "baseline/",
    "README.md",
    "opencode/dist/"
  ],
  "publishConfig": {
    "registry": "https://npm.enterprise.com/",
    "access": "restricted"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "keywords": [
    "sdd",
    "claude-code",
    "plugin",
    "enterprise"
  ],
  "license": "UNLICENSED",
  "private": false,
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
