#!/usr/bin/env bash
# scripts/dop — mock 企业 dop CLI（对齐真实契约，2026-07-06 校准）
#
# 真实契约（来自内网 `dop change --help`）：
#   - dop change create / list / view  （只有这 3 个子命令，无 update）
#   - 全局 flag：--endpoint string、-j/--json
#   - 默认 endpoint：http://10.182.35.66
#   - change view JSON 字段契约（2026-07-06 校准，对齐 sdd-doc 排期信息章节需求）：
#       id, title, status, type, owner, description, acceptance_criteria, created_at
#     + sub_systems:        [{code, name}]      # 子系统列表
#     + user_stories:       [{                  # 用户故事（一个 change 可有多个）
#         id, code, title, type, state, stage, team, assignee, business_owner,
#         release_info: {                      # ← 排期信息（sdd-doc 1.1 排期信息章节用）
#           release_num,                       # 排期编号（如 R20260508012）
#           release_name,                      # 排期名称
#           release_date,                      # 排期日期
#           release_stage                      # 排期阶段
#         }
#       }]
#
# 改造说明（2026-06-22，Q1=A 决策）：
#   原 mock 的 `change update` 子命令已删除——真实 dop 不支持。
#   skills 改为通过 .meta.json 本地记录进度，不再调 dop CLI 上报状态。
#
# 已知 change-id 测试数据：
#   ARD123456  → "用户测试demo"  → 1 个 user_story，含 release_info
#   ARD222222  → "信用卡积分兑换功能" → 2 个 user_story，首个 release_info 为空（验证"取首个非空"逻辑）

set -euo pipefail

VERSION="dop mock v0.2.0-dev"
DEFAULT_ENDPOINT="http://10.182.35.66"
LOG_FILE="${OMS_MOCK_DOP_LOG:-$HOME/.oh-my-sdd/logs/mock-dop.log}"
USER="${OMS_MOCK_DOP_USER:-alice}"
ENDPOINT="$DEFAULT_ENDPOINT"
JSON_MODE=0

mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true

log() {
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] $*" >> "$LOG_FILE"
}

change_list() {
  log "change list (endpoint=$ENDPOINT json=$JSON_MODE)"

  if [[ "${OMS_MOCK_DOP_FAIL_GET:-0}" == "1" ]]; then
    echo "❌ dop change list failed (forced)" >&2
    exit 1
  fi

  cat <<EOF
{
  "user": "$USER",
  "total": 2,
  "changes": [
    {"id": "ARD123456", "title": "用户测试demo", "status": "open", "type": "feature"},
    {"id": "ARD222222", "title": "信用卡积分兑换功能", "status": "open", "type": "feature"}
  ]
}
EOF
}

change_view() {
  local id="$1"
  log "change view $id (endpoint=$ENDPOINT json=$JSON_MODE)"

  if [[ "${OMS_MOCK_DOP_FAIL_GET:-0}" == "1" ]]; then
    echo "❌ dop change view failed (forced)" >&2
    exit 1
  fi

  case "$id" in
    ARD123456)
      cat <<EOF
{
  "id": "$id",
  "title": "用户测试demo",
  "status": "open",
  "type": "feature",
  "owner": "$USER",
  "description": "用户测试 demo - 用于验证 oh-my-sdd 端到端流程",
  "acceptance_criteria": [
    "可以走完 SDD 5 环流程",
    "openspec/specs/ 被 archive merge 更新",
    "gh issue + PR 自动关联"
  ],
  "created_at": "2026-06-20T00:00:00Z",
  "sub_systems": [
    {"code": "ARD.ard-sdk", "name": "智能研发平台.AI原生框架套件"}
  ],
  "user_stories": [
    {
      "id": "c7fe4770a27841a48dd26d20c49da8b",
      "code": "US-95376",
      "title": "用户测试 demo 故事",
      "type": "主动故事",
      "state": "正常",
      "stage": "已上线",
      "team": "统一开发平台",
      "assignee": "$USER",
      "business_owner": "$USER",
      "release_info": {
        "release_num": "R20260620001",
        "release_name": "用户测试 demo 排期",
        "release_date": "2026-06-25T00:00:00Z",
        "release_stage": "投产实施"
      }
    }
  ]
}
EOF
      ;;
    ARD222222)
      cat <<EOF
{
  "id": "$id",
  "title": "信用卡积分兑换功能",
  "status": "open",
  "type": "feature",
  "owner": "$USER",
  "description": "用户可以使用信用卡积分兑换商品/服务",
  "acceptance_criteria": [
    "用户在 app 看到积分余额",
    "可选择商品兑换",
    "兑换成功后扣减积分"
  ],
  "created_at": "2026-06-20T00:00:00Z",
  "sub_systems": [
    {"code": "CARD.points-mall", "name": "信用卡中心.积分商城子系统"}
  ],
  "user_stories": [
    {
      "id": "a1b2c3d4e5f6789012345abcdef67890",
      "code": "US-10001",
      "title": "积分余额查询",
      "type": "主动故事",
      "state": "正常",
      "stage": "已上线",
      "team": "信用卡中心",
      "assignee": "$USER",
      "business_owner": "$USER",
      "release_info": null
    },
    {
      "id": "b2c3d4e5f6789012345abcdef67890a",
      "code": "US-10002",
      "title": "积分兑换商品",
      "type": "主动故事",
      "state": "正常",
      "stage": "已上线",
      "team": "信用卡中心",
      "assignee": "$USER",
      "business_owner": "$USER",
      "release_info": {
        "release_num": "R20260620002",
        "release_name": "积分商城首期上线",
        "release_date": "2026-07-10T00:00:00Z",
        "release_stage": "投产实施"
      }
    }
  ]
}
EOF
      ;;
    *)
      echo "❌ Change not found: $id" >&2
      echo "已知测试 id: ARD123456 (用户测试demo), ARD222222 (信用卡积分)" >&2
      exit 1
      ;;
  esac
}

change_create() {
  log "change create (endpoint=$ENDPOINT json=$JSON_MODE)"

  if [[ "${OMS_MOCK_DOP_FAIL_UPDATE:-0}" == "1" ]]; then
    echo "❌ dop change create failed (forced)" >&2
    exit 1
  fi

  # mock：生成新 change-id（格式 ARDdddddd）
  local new_id="ARD$((100000 + RANDOM % 899999))"
  cat <<EOF
{
  "id": "$new_id",
  "status": "open",
  "type": "feature",
  "owner": "$USER",
  "created_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
EOF
}

print_change_help() {
  cat <<EOF
Usage:
  dop change [command]

Available Commands:
  create      Create a new system change
  list        List system changes
  view        View system change details

Flags:
  -h, --help   help for change

Global Flags:
      --endpoint string   API endpoint URL (overrides config) (default "$DEFAULT_ENDPOINT")
  -j, --json             Enable JSON mode for request and response info.
                        Force all output to valid JSON

Use "dop change [command] --help" for more information about a command.
EOF
}

# ============================================================
# Main dispatch
# ============================================================
# 先解析全局 flag（原地修改 ENDPOINT 和 JSON_MODE），留下 subcmd 和它的参数
REMAINING=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --endpoint)
      ENDPOINT="$2"; shift 2 ;;
    --endpoint=*)
      ENDPOINT="${1#--endpoint=}"; shift ;;
    -j|--json)
      JSON_MODE=1; shift ;;
    *)
      REMAINING+=("$1"); shift ;;
  esac
done

cmd="${REMAINING[0]:-}"
subcmd="${REMAINING[1]:-}"

case "$cmd" in
  change)
    case "$subcmd" in
      list)   change_list ;;
      view)   change_view "${REMAINING[2]:-}" ;;
      create) change_create ;;
      -h|--help|"") print_change_help ;;
      *)
        # 兼容已废弃的 update：明确告知用户
        if [[ "$subcmd" == "update" ]]; then
          cat >&2 <<EOF
❌ dop change update 不存在。

真实 dop CLI 只有 create / list / view 三个子命令（见 dop change --help）。
oh-my-sdd 已迁移到 .meta.json 本地记录进度方案（Q1=A 决策）。

如果你的 skill 还在调 change update，请更新到最新版本。
EOF
          exit 1
        fi
        echo "Error: unknown command \"dop change $subcmd\"" >&2
        echo "Run 'dop change --help' for usage." >&2
        exit 1
        ;;
    esac
    ;;

  -h|--help|"")
    cat <<EOF
dop mock CLI v0.2.0-dev — 对齐企业真实契约（2026-06-22）

Usage:
  dop [command]

Available Commands:
  change      Manage system changes (create / list / view)

Flags:
  -h, --help   help for dop

Global Flags:
      --endpoint string   API endpoint URL (default "$DEFAULT_ENDPOINT")
  -j, --json             Enable JSON mode

Use "dop [command] --help" for more information about a command.

已知测试 change-id:
  ARD123456              "用户测试demo"
  ARD222222              "信用卡积分兑换功能"

环境变量:
  OMS_MOCK_DOP_USER        用户名（默认 alice）
  OMS_MOCK_DOP_FAIL_GET    =1 时 change view/list 模拟失败
  OMS_MOCK_DOP_FAIL_UPDATE =1 时 change create 模拟失败
  OMS_MOCK_DOP_LOG         日志路径（默认 ~/.oh-my-sdd/logs/mock-dop.log）

注意: change update 子命令已被移除（对齐真实 dop）。
EOF
    ;;

  *)
    echo "Error: unknown command \"$cmd\" for \"dop\"" >&2
    echo "Run 'dop --help' for usage." >&2
    exit 1
    ;;
esac
